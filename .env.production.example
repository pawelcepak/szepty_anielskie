NODE_ENV=production
PORT=3000

# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Operator bootstrap (only when operators table is empty)
OPERATOR_BOOTSTRAP_EMAIL=pawel.cepak94@gmail.com
OPERATOR_BOOTSTRAP_PASSWORD=Kanada!994
OPERATOR_BOOTSTRAP_NAME=Pawel

# Public URL (maile, sitemap, canonical) — obowiązkowe w produkcji
