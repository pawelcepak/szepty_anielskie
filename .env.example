PORT=3002
# Testowe doładowanie wiadomości (10/20/50/100) — w produkcji: false
ALLOW_FAKE_PURCHASE=true

# Pierwszy operator tworzony automatycznie, jeśli baza nie ma żadnego konta operatorskiego
OPERATOR_BOOTSTRAP_EMAIL=kanadyjczyk994@gmail.com
OPERATOR_BOOTSTRAP_PASSWORD=Kanada!994
OPERATOR_BOOTSTRAP_NAME=administraror

# Publiczna ścieżka panelu operatora (nie wystawiaj przewidywalnego /operator na produkcji — ustaw długi losowy segment)
# OPERATOR_PANEL_PATH=/operator

# Pracownik: pula ręczna (max widocznych slotów), terminy, pierwszeństwo po odpowiedzi klienta
# STAFF_REPLY_DEADLINE_MINUTES=6
# STAFF_REMINDER_AFTER_STAFF_HOURS=48
# STAFF_IDLE_KICK_MINUTES=2
# STAFF_RECLAIM_WINDOW_MINUTES=1
# STAFF_RESUME_PRIORITY_MINUTES=4
# STAFF_QUEUE_VISIBLE_MAX=5
# STAFF_REPLY_MIN_CHARS=100
# STAFF_REPLY_MAX_CHARS=900
# OWNER_REPLY_MIN_CHARS=20
# OWNER_REPLY_MAX_CHARS=1500
# Po 48 h bez odpowiedzi klienta wątek trafia do „Zatrzymane” (STAFF_REMINDER_AFTER_STAFF_HOURS, domyślnie 48)

# Frazy (małe litery, podciągi) zabronione w odpowiedzi pracownika do klienta — rozdziel przecinkiem lub średnikiem
# STAFF_REPLY_BANNED_SUBSTRINGS=telefon,email,e-mail,policja,agent czatu

# Teksty na podstronach administratora (GET /api/op/console/meta)
# KYC_VENDOR_NAME=Onfido / Veriff / …
# KYC_FLOW_DESCRIPTION=Krótki opis przepływu dla zespołu
# HR_SUPPORT_PIPELINE_NOTES=Np. kiedy planujesz zatrudnić osoby tylko do obsługi pracowników

# Szacunkowa stawka za jedną odpowiedź pracownika (PLN) — używana w statystykach / „Moje konto” (~0,09 EUR wg kursu)
# STAFF_RATE_PLN_PER_REPLY=0.45

# Ceny pakietów wiadomości dla klienta (PLN, wyświetlane na stronie i w panelu — do bramki płatności)
# CLIENT_PKG_10_PLN=19.99
# CLIENT_PKG_20_PLN=34.99
# CLIENT_PKG_50_PLN=74.99
# CLIENT_PKG_100_PLN=129.99

# Kontakty widoczne pracownikowi na stronie moje.html w panelu operatora (ścieżka = OPERATOR_PANEL_PATH)
# OWNER_CONTACT_EMAIL=wlasciciel@wrozki.pl
# STAFF_SUPPORT_EMAIL=obsluga_klienta@wrozki.pl
# STAFF_SUPPORT_TEAMS_URL=https://teams.microsoft.com/l/wrozki_pracownicy

# Panel właściciela — zakładka „Audyt zespołu”: premie tygodniowe (kwoty orientacyjne, wypłata ręczna / później automat)
# STAFF_BONUS_TOP1_WEEK_PLN=150
# STAFF_BONUS_TOP2_WEEK_PLN=100
# STAFF_BONUS_TOP3_WEEK_PLN=50
# Krótka notatka wyświetlana zespołowi (np. wyróżnienie tygodnia) — tylko tekst, bez logiki
# STAFF_SPOTLIGHT_WEEK_MESSAGE=
# Własny opis planu poleceń / ocen po rozmowie (wkrótce w produkcji)
# STAFF_RECOMMENDATION_HINT=

# Publiczny URL serwisu (linki w mailach: weryfikacja konta, zmiana e-mail)
# PUBLIC_BASE_URL=https://twoja-domena.pl

# SEO launch lock (na testach: false = noindex + robots disallow)
# SEO_INDEXABLE=false

# Treści maili systemowych — opcjonalnie; domyślne szablony są w kodzie (mail.js).
# Placeholdery: {{name}} (imię), {{verifyUrl}} lub {{confirmUrl}}, {{hours}} (ważność linku w godzinach).
# MAIL_LINK_EXPIRY_HOURS=48   (spójne z ważnością tokenu w bazie)
#
# MAIL_SUBJECT_EMAIL_VERIFICATION=Potwierdź adres e-mail — Szepty Anielskie
# MAIL_TEXT_EMAIL_VERIFICATION=Cześć {{name}},\n\n\nOtwórz link, aby potwierdzić konto:\n{{verifyUrl}}\n\n\n\nLink jest ważny {{hours}} godzin.\n
# MAIL_HTML_EMAIL_VERIFICATION=   (puste = prosty HTML z kodu; albo własny HTML z {{nameHtml}} {{verifyUrl}} {{hours}})
#
# MAIL_SUBJECT_EMAIL_CHANGE=Potwierdź zmianę adresu e-mail — Szepty Anielskie
# MAIL_TEXT_EMAIL_CHANGE=Cześć {{name}},\n\nPotwierdź zmianę adresu e-mail klikając link:\n{{confirmUrl}}\n\nLink jest ważny {{hours}} godzin.\n
# MAIL_HTML_EMAIL_CHANGE=

# Formularz kontaktowy (docelowo podmień na właściwy adres odbiorczy)
# CONTACT_FORM_TO=noreply@localhost

# Moduł promocji / kuponów (przygotowany pod przyszłe kampanie z linków TikTok/Instagram)
# PROMO_SYSTEM_ENABLED=true   # domyslnie wlaczone; ustaw false aby wylaczyc
# PROMO_POPUP_ENABLED=true    # domyslnie wlaczone; ustaw false aby wylaczyc popup

# Przelewy24 (szkielet integracji — aktywujesz po utworzeniu konta P24)
# P24_ENABLED=false
# P24_SANDBOX=true
# P24_MERCHANT_ID=
# P24_POS_ID=
# P24_CRC=
# P24_API_KEY=

# PayU (gdy wszystkie zmienne ustawione i PAYU_ENABLED=true — wtedy możliwy checkout PayU, o ile nie wygrywa Autopay)
# PAYU_ENABLED=false
# PAYU_SANDBOX=false
# PAYU_POS_ID=
# PAYU_MD5_KEY=
# PAYU_CLIENT_ID=
# PAYU_CLIENT_SECRET=

# Autopay (Blue Media) — SHA256, produkcja: https://pay.autopay.eu/payment
# Gdy AUTOPAY_SERVICE_ID + AUTOPAY_HASH_KEY są ustawione, kasa klienta używa Autopay; PayU jest wtedy ukryty w UI.
# W panelu Autopay ustaw adres ITN: {PUBLIC_BASE_URL}/api/payments/autopay/itn
# AUTOPAY_SERVICE_ID=210402
# AUTOPAY_HASH_KEY=   # klucz współdzielony z panelu Autopay (nie commituj do repo)
# AUTOPAY_PAYMENT_URL=https://pay.autopay.eu/payment

# Asystent AI w panelu operatora (generowanie szkicu odpowiedzi)
# Ustaw jeden lub oba klucze:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=gpt-image-1
# ANTHROPIC_API_KEY=sk-ant-api03-...   (klucz z https://console.anthropic.com/ → API Keys, nie „MCP”)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Alternatywnie pełny ID: claude-haiku-4-5-20251001 (docs.anthropic.com — modele się zmieniają; unikaj starych „-latest”)